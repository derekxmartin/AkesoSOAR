# AkesoSOAR Environment Configuration

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akeso_soar
POSTGRES_USER=akeso
POSTGRES_PASSWORD=changeme_in_production

# Database URL (constructed from above, or override directly)
DATABASE_URL=postgresql+asyncpg://akeso:changeme_in_production@localhost:5432/akeso_soar

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true

# JWT Authentication
JWT_SECRET_KEY=replace-with-a-secure-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Encryption key for connector secrets (Fernet)
SECRETS_ENCRYPTION_KEY=replace-with-fernet-key
