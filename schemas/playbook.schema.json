{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AkesoSOAR Playbook",
  "type": "object",
  "required": ["name", "steps"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "enabled": { "type": "boolean", "default": true },
    "trigger": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["alert", "manual", "scheduled"] },
        "conditions": {
          "type": "object",
          "properties": {
            "sigma_rule_id": { "type": "string" },
            "severity_gte": { "type": "string", "enum": ["critical", "high", "medium", "low", "informational"] },
            "custom_filter": { "type": "string" }
          }
        }
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["action", "condition", "human_task", "transform", "parallel"] },
          "action": {
            "type": "object",
            "required": ["connector", "operation"],
            "properties": {
              "connector": { "type": "string" },
              "operation": { "type": "string" },
              "params": { "type": "object", "additionalProperties": true }
            }
          },
          "condition": {
            "type": "object",
            "required": ["expression", "branches"],
            "properties": {
              "expression": { "type": "string" },
              "branches": {
                "type": "object",
                "properties": {
                  "true": { "type": "string" },
                  "false": { "type": "string" }
                },
                "required": ["true", "false"]
              }
            }
          },
          "human_task": {
            "type": "object",
            "required": ["prompt", "assignee_role"],
            "properties": {
              "prompt": { "type": "string" },
              "assignee_role": { "type": "string" },
              "timeout_hours": { "type": "integer", "minimum": 1 },
              "on_timeout": { "type": "string" }
            }
          },
          "transform": {
            "type": "object",
            "properties": {
              "expression": { "type": "string" },
              "output_var": { "type": "string" }
            }
          },
          "parallel": {
            "type": "object",
            "required": ["branches"],
            "properties": {
              "branches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["steps"],
                  "properties": {
                    "steps": { "type": "array", "items": { "type": "string" } }
                  }
                }
              },
              "join": { "type": "string", "enum": ["all", "any"], "default": "all" }
            }
          },
          "on_success": { "type": "string" },
          "on_failure": { "type": "string" },
          "timeout_seconds": { "type": "integer", "minimum": 1 },
          "retry": {
            "type": "object",
            "properties": {
              "max_attempts": { "type": "integer", "minimum": 1 },
              "backoff_seconds": { "type": "integer", "minimum": 1 }
            }
          },
          "rollback_action": {
            "type": "object",
            "properties": {
              "connector": { "type": "string" },
              "operation": { "type": "string" },
              "params": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "action" } } },
            "then": { "required": ["action"] }
          },
          {
            "if": { "properties": { "type": { "const": "condition" } } },
            "then": { "required": ["condition"] }
          },
          {
            "if": { "properties": { "type": { "const": "human_task" } } },
            "then": { "required": ["human_task"] }
          },
          {
            "if": { "properties": { "type": { "const": "parallel" } } },
            "then": { "required": ["parallel"] }
          }
        ]
      }
    }
  }
}
